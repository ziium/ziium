(* v0.1 parser grammar *)
(* The lexer is responsible for splitting attached particles.
   Example: "사람의" -> IDENT("사람") GEN("의") *)

program         = { newline }, { statement, { newline } }, EOF ;

statement       = bind_stmt
                | assign_stmt
                | print_stmt
                | sleep_stmt
                | return_stmt
                | if_stmt
                | while_stmt
                | function_def
                | keyword_message_stmt
                | named_call_stmt
                | call_stmt
                ;

bind_stmt       = IDENT, TOPIC, ( expression, COPULA | resultive_expr ), [ PERIOD ] ;
assign_stmt     = IDENT, OBJECT, expression, DIRECTION, CHANGE, [ PERIOD ] ;
print_stmt      = expression, OBJECT, PRINT, [ PERIOD ] ;
sleep_stmt      = expression, SECOND_UNIT, SLEEP, [ PERIOD ] ;
return_stmt     = expression, OBJECT, RETURN, [ PERIOD ] ;
keyword_message_stmt
                = expression, LOCATIVE, expression, [ DIRECTION ], IDENT, [ PERIOD ] ;
named_call_stmt = expression, OBJECT, expression, DIRECTION, CALL_VERB, [ PERIOD ] ;
call_stmt       = call_like_expr, [ PERIOD ] ;

if_stmt         = expression, IF,
                  newline, INDENT, block, DEDENT,
                  [ ELSE, newline, INDENT, block, DEDENT ] ;

while_stmt      = expression, IN, DURING,
                  newline, INDENT, block, DEDENT ;

function_def    = IDENT, FUNCTION, FUNCTION_TOPIC,
                  (
                    param_list, OBJECT, RECEIVE
                  | NOTHING, RECEIVE_NOT, RECEIVE_NEG
                  ),
                  newline, INDENT, block, DEDENT ;

block           = statement, { newline, statement }, { newline } ;

param_list      = IDENT, { COMMA, IDENT } ;
arg_list        = expression, { COMMA, expression } ;

expression      = logic_or ;

logic_or        = logic_and, { OR, logic_and } ;
logic_and       = equality, { AND, equality } ;
equality        = comparison, { ( EQ | NE ), comparison } ;
comparison      = additive, { ( LT | LE | GT | GE ), additive } ;
additive        = multiplicative, { ( PLUS | MINUS | ADD_WORD | SUB_WORD ), multiplicative } ;
multiplicative  = unary, { ( STAR | SLASH | PERCENT | MUL_WORD | DIV_WORD ), unary } ;
unary           = { ( MINUS | NOT ) }, postfix ;

postfix         = primary, { call_suffix | transform_suffix | index_suffix | property_suffix } ;
call_like_expr  = primary,
                  { index_suffix | property_suffix },
                  ( call_suffix | transform_suffix ),
                  { call_suffix | transform_suffix | index_suffix | property_suffix } ;

call_suffix     = LPAREN, [ arg_list ], RPAREN ;
transform_suffix = DIRECTION, IDENT ;
index_suffix    = LBRACKET, expression, RBRACKET ;
property_suffix = GEN, IDENT ;
resultive_expr  = expression, FROM, TOP_DISK, OBJECT, POP_RESULT ;

primary         = IDENT
                | INT
                | FLOAT
                | STRING
                | TRUE
                | FALSE
                | NONE
                | list_literal
                | record_literal
                | LPAREN, expression, RPAREN
                ;

list_literal    = LBRACKET, [ expression, { COMMA, expression } ], RBRACKET ;
record_literal  = LBRACE, [ record_entry, { COMMA, record_entry } ], RBRACE ;
record_entry    = named_record_entry | shorthand_record_entry ;
named_record_entry
                = ( IDENT | STRING ), COLON, expression ;
shorthand_record_entry
                = IDENT ;

newline         = NEWLINE ;

(* token aliases *)
TOPIC           = "은" | "는" ;
OBJECT          = "을" | "를" ;
GEN             = "의" ;
LOCATIVE        = "에" ;
FROM            = "에서" ;
DIRECTION       = "로" | "으로" ;
PERIOD          = "." ;
COPULA          = "이다" ;
IF              = "이면" ;
ELSE            = "아니면" ;
IN              = "인" ;
DURING          = "동안" ;
FUNCTION        = "함수" ;
FUNCTION_TOPIC  = "는" ;
RECEIVE         = "받아" ;
NOTHING         = "아무것도" ;
RECEIVE_NOT     = "받지" ;
RECEIVE_NEG     = "않아" ;
PRINT           = "출력한다" ;
RETURN          = "돌려준다" ;
CHANGE          = "바꾼다" ;
TRUE            = "참" ;
FALSE           = "거짓" ;
NONE            = "없음" ;
AND             = "그리고" ;
OR              = "또는" ;
NOT             = "아니다" ;
ADD_WORD        = IDENT("더하기") ;
SUB_WORD        = IDENT("빼기") ;
MUL_WORD        = IDENT("곱하기") ;
DIV_WORD        = IDENT("나누기") ;
SECOND_UNIT     = IDENT("초") ;
SLEEP           = IDENT("쉬기") ;
TOP_DISK        = IDENT("맨위"), IDENT("원반") ;
POP_RESULT      = IDENT("빼낸"), RESULT_MARKER ;
RESULT_MARKER   = "것이다" ;
CALL_VERB       = IDENT("호출한다") ;

(* Primitive lexer tokens such as IDENT, INT, FLOAT, STRING, NEWLINE,
   INDENT, DEDENT, EOF and punctuation/operator tokens like LPAREN,
   RPAREN, LBRACKET, RBRACKET, LBRACE, RBRACE, COMMA, COLON, PLUS,
   MINUS, STAR, SLASH, PERCENT, EQ, NE, LT, LE, GT, GE are emitted
   directly by the lexer. *)
